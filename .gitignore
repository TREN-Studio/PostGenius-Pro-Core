# ========================================
# TREN Studio: Security & Privacy Protocol
# ========================================

# Do NOT commit raw API responses, temporary files, or cached endpoints
tmp_*/
tmp-*.png
tmp_*.json
tmp_*.txt
tmp_*.php
tmp_*.js
tmp_*.mjs
tmp_*.html
tmp_*.b64

