<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /
  
  # Allow access to existing files and directories (API, Assets, etc.)
  RewriteCond %{REQUEST_FILENAME} -f [OR]
  RewriteCond %{REQUEST_FILENAME} -d
  RewriteRule ^ - [L]

  # Redirect everything else to index.html (SPA Routing)
  RewriteRule ^ index.html [L]
</IfModule>

# Optional: Add CORS headers globally if needed, though we did it in api/uploads
<IfModule mod_headers.c>
    Header set Access-Control-Allow-Origin "*"
</IfModule>
