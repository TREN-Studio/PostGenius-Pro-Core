# ====================================================
# 🛡️ PostGenius-Pro-Core - Environment Setup
# TREN Studio | Official Community Edition Template
# ====================================================

# ⚠️ DO NOT COMMIT THIS FILE WITH REAL VALUES ⚠️
# Copy this file to `.env` and fill in your keys.

# ----------------------------------------
# 🚀 1. Core Platform Settings
# ----------------------------------------
VITE_APP_URL="http://localhost:3000"
VITE_APP_NAME="PostGenius Pro | TREN Studio Edition"
VITE_API_ENDPOINT="http://localhost:5000/api"

# ----------------------------------------
# 🧠 2. DeepMind & OpenAI Models (Agent Logic)
# ----------------------------------------
# Required for autonomous reasoning and review structuring
GEMINI_API_KEY="your_gemini_api_key_here"
OPENAI_API_KEY="your_openai_api_key_here"

# ----------------------------------------
# 📸 3. NVIDIA Images API (The Studio Renderer)
# ----------------------------------------
# Provides the cinematic output for comparison tables and hero images
NVIDIA_NIM_API_KEY="your_nvidia_nim_key_here"
STABLE_DIFFUSION_MODEL_ID="stable-diffusion-3-medium"
QWEN_VLM_MODEL_ID="qwen/qwen3.5-397b-a17b"

# ----------------------------------------
# 🛒 4. Amazon Product Advertising API (PA-API)
# ----------------------------------------
# Essential for retrieving the live pricing and ASIN images
AMAZON_ACCESS_KEY_ID="your_amazon_access_key"
AMAZON_SECRET_KEY="your_amazon_secret_key"
AMAZON_PARTNER_TAG="your_affiliate_tag-20"
AMAZON_HOST="webservices.amazon.com"
AMAZON_REGION="us-east-1"

# ----------------------------------------
# 📍 5. Pinterest API (The Marketing Engine)
# ----------------------------------------
# Automatically pin generated graphics and reviews
PINTEREST_CLIENT_ID="your_pinterest_app_id"
PINTEREST_CLIENT_SECRET="your_pinterest_app_secret"
PINTEREST_REDIRECT_URI="http://localhost:3000/auth/pinterest/callback"

# ----------------------------------------
# 🔒 6. Security & Vault Settings
# ----------------------------------------
# A high-entropy 256-bit string to sign JWTs and encryptions
SUPABASE_JWT_SECRET="generate_a_secure_token_here"
SUPABASE_URL="https://your-project.supabase.co"
SUPABASE_ANON_KEY="your_supabase_anon_key"

# End of .env.example
