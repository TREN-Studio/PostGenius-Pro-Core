# HuggingFace Configuration
HF_TOKEN=your_huggingface_token_here

# Flask Configuration
FLASK_ENV=development
PYTHON_PORT=5000

# Get your HuggingFace token at:
# https://huggingface.co/settings/tokens

# =====================================
# NVIDIA AI Integration Configuration
# =====================================

# NVIDIA NIM API Key - Get from https://console.groq.com/
# Required for Stable Diffusion 3.5 and Qwen VLM integration
NVIDIA_API_KEY=your_nvidia_api_key_here

# Stable Diffusion Model ID
# Note: on NVIDIA hosted API, stable-diffusion-3-medium is widely available.
STABLE_DIFFUSION_MODEL_ID=stable-diffusion-3-medium

# Qwen VLM Model ID (use full provider/model format)
QWEN_VLM_MODEL_ID=qwen/qwen3.5-397b-a17b

# =====================================
# Pinterest OAuth Configuration
# =====================================

# Pinterest App Credentials
# Register your app at: https://developers.pinterest.com/
PINTEREST_CLIENT_ID=your_pinterest_client_id
PINTEREST_CLIENT_SECRET=your_pinterest_client_secret

# Pinterest OAuth Redirect URI (must match app settings)
PINTEREST_REDIRECT_URI=https://postgeniuspro.com/api/pinterest/callback

